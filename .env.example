# 텔레그램 봇 토큰 (@BotFather 에서 발급)
TELEGRAM_TOKEN=your-telegram-bot-token-here

# 본인 텔레그램 chat_id (숫자)
# test_telegram.py 실행 후 확인 가능
TELEGRAM_CHAT_ID=000000000

# Claude API 키 (선택 — 없으면 AI 분석 비활성화)
CLAUDE_API_KEY=

# 승인 타임아웃 (초, 기본값 300 = 5분)
APPROVAL_TIMEOUT=300

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# 새 작업 시 참조할 직전 작업 요약본 개수 (0 = 비활성)
# 작업 완료 때마다 결과를 1~2문장으로 요약 저장하고, 다음 작업에 최근 N개를 주입한다.
WORKER_MEMORY_COUNT=3

# /commit 으로 생성되는 로컬 커밋의 author
GIT_AUTHOR_NAME=devops-pipeline bot
GIT_AUTHOR_EMAIL=bot@devops-pipeline.local
# /push 용 GitHub Personal Access Token (선택 — 미설정 시 /push 비활성)
# Fine-grained PAT 권장: 이 repo 한정, 권한 Contents = Read and write
# 발급: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=

# ── 작업 이력 DB ───────────────────────────────────────────────────────────────
# sqlite (기본, 추가 인프라 불필요) | postgres (docker compose --profile postgres)
DB_BACKEND=sqlite
# DB_BACKEND=postgres 일 때 사용. postgres 서비스명/포트/자격증명
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tasks
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=changeme

# Notion 통합 (선택 — /stack 명령어 사용 시 필요)
# 발급: https://www.notion.so/profile/integrations (Internal Integration Token)
NOTION_TOKEN=
# /stack 으로 생성되는 페이지의 부모 페이지 ID
# 해당 페이지에 위 Integration 을 공유(Connect)해야 워커가 접근 가능
NOTION_PARENT_PAGE_ID=

# ── 최신 자료 조사 (last30days 스킬, 선택) ──────────────────────────────────────
# stack/doc/general 에이전트가 시의성 있는 주제에 호출하는 recent_research 도구.
# Reddit/HN 은 키 없이 동작. true 면 활성화, false 면 도구 미노출.
RESEARCH_ENABLED=true
# 조회 소스 (쉼표 구분). 키리스 기본값. X/YouTube 등은 해당 API 키 추가 시 가능.
RESEARCH_SOURCES=reddit,hackernews
# 조회 기간(일)
RESEARCH_DAYS=30
# CLI 1회 실행 타임아웃(초) — WORKER_TIMEOUT_S 보다 작게 유지
RESEARCH_TIMEOUT_S=90

# ── vLLM (선택) ────────────────────────────────────────────────────────────────
# 설정 시 Claude API 대신 로컬 vLLM 사용 (Claude API 키 불필요)
# docker compose --profile vllm up 으로 vLLM 컨테이너 실행 후 설정
VLLM_ENDPOINT=
# 서빙할 모델 (HuggingFace Hub 모델 ID)
VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
# GPU 메모리 사용률 (0~1, 기본 0.7). 작은 GPU/공유 환경에서 낮춤
VLLM_GPU_MEMORY_UTILIZATION=0.7
# 도구 호출 파서 (에이전트 tool calling 용). Qwen2.5=hermes, Llama3.1=llama3_json 등
VLLM_TOOL_PARSER=hermes
# 총 컨텍스트 길이(입력+출력). docker-compose 의 --max-model-len 과 일치시킬 것
VLLM_MAX_MODEL_LEN=4096
# 라우트별 백엔드 분기 — 여기 나열된 라우트만 vLLM, 나머지는 Claude (쉼표 구분)
# 기본: general(단순)만 vLLM, code/doc/infra/stack(품질·도구)은 Claude
VLLM_ROUTES=general
# 모델 다운로드용 HuggingFace 토큰 (gated 모델 사용 시 필요)
HUGGING_FACE_HUB_TOKEN=

# ── 모니터링 (선택) ────────────────────────────────────────────────────────────
# docker compose --profile monitoring up 으로 Prometheus + Grafana 실행
GRAFANA_ADMIN_PASSWORD=changeme

# ── 레지스트리 이미지 실행 (선택) ──────────────────────────────────────────────
# docker-compose.registry.yml 사용 시 끌어올 이미지. 비워두면 기본값 사용.
# 포크/다른 org 사용 시 여기에 ghcr.io/<org>/devops-pipeline:<tag> 지정.
APP_IMAGE=ghcr.io/currentjob/devops-pipeline:latest
