# 텔레그램 봇 토큰 (@BotFather 에서 발급)
TELEGRAM_TOKEN=your-telegram-bot-token-here

# 본인 텔레그램 chat_id (숫자)
# test_telegram.py 실행 후 확인 가능
TELEGRAM_CHAT_ID=000000000

# Claude API 키 (선택 — 없으면 AI 분석 비활성화)
CLAUDE_API_KEY=

# 승인 타임아웃 (초, 기본값 300 = 5분)
APPROVAL_TIMEOUT=300

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# Notion 통합 (선택 — /stack 명령어 사용 시 필요)
# 발급: https://www.notion.so/profile/integrations (Internal Integration Token)
NOTION_TOKEN=
# /stack 으로 생성되는 페이지의 부모 페이지 ID
# 해당 페이지에 위 Integration 을 공유(Connect)해야 워커가 접근 가능
NOTION_PARENT_PAGE_ID=

# ── vLLM (선택) ────────────────────────────────────────────────────────────────
# 설정 시 Claude API 대신 로컬 vLLM 사용 (Claude API 키 불필요)
# docker compose --profile vllm up 으로 vLLM 컨테이너 실행 후 설정
VLLM_ENDPOINT=
# 서빙할 모델 (HuggingFace Hub 모델 ID)
VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
# GPU 메모리 사용률 (0~1, 기본 0.7). 작은 GPU/공유 환경에서 낮춤
VLLM_GPU_MEMORY_UTILIZATION=0.7
# 도구 호출 파서 (에이전트 tool calling 용). Qwen2.5=hermes, Llama3.1=llama3_json 등
VLLM_TOOL_PARSER=hermes
# 모델 다운로드용 HuggingFace 토큰 (gated 모델 사용 시 필요)
HUGGING_FACE_HUB_TOKEN=

# ── 모니터링 (선택) ────────────────────────────────────────────────────────────
# docker compose --profile monitoring up 으로 Prometheus + Grafana 실행
GRAFANA_ADMIN_PASSWORD=changeme

# ── 레지스트리 이미지 실행 (선택) ──────────────────────────────────────────────
# docker-compose.registry.yml 사용 시 끌어올 이미지. 비워두면 기본값 사용.
# 포크/다른 org 사용 시 여기에 ghcr.io/<org>/devops-pipeline:<tag> 지정.
APP_IMAGE=ghcr.io/currentjob/devops-pipeline:latest
