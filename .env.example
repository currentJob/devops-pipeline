# 텔레그램 봇 토큰 (@BotFather 에서 발급)
TELEGRAM_TOKEN=your-telegram-bot-token-here

# 본인 텔레그램 chat_id (숫자)
# test_telegram.py 실행 후 확인 가능
TELEGRAM_CHAT_ID=000000000

# Claude API 키 (선택 — 없으면 AI 분석 비활성화)
CLAUDE_API_KEY=

# 승인 타임아웃 (초, 기본값 300 = 5분)
APPROVAL_TIMEOUT=300

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# Notion 통합 (선택 — /stack 명령어 사용 시 필요)
# 발급: https://www.notion.so/profile/integrations (Internal Integration Token)
NOTION_TOKEN=
# /stack 으로 생성되는 페이지의 부모 페이지 ID
# 해당 페이지에 위 Integration 을 공유(Connect)해야 워커가 접근 가능
NOTION_PARENT_PAGE_ID=
