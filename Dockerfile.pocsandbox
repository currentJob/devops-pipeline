# PoC 격리 실행 사이드카 — docker CLI + compose plugin + python3(stdlib only).
# docker.sock 이 이 컨테이너에만 마운트된다. PoC 를 build + 격리 단일 실행 후 teardown.
FROM docker:29-cli

RUN apk add --no-cache python3

WORKDIR /app
# app 패키지는 가벼움 — checks.py(순수) + server.py(stdlib) 만 필요
COPY app/__init__.py ./app/__init__.py
COPY app/pocsandbox/ ./app/pocsandbox/

ENV PYTHONUNBUFFERED=1
EXPOSE 8770

CMD ["python3", "-m", "app.pocsandbox.server"]
